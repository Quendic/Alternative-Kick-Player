<resources xmlns:tools="http://schemas.xml-auto.org">
    <!-- Base application theme. -->
    <style name="Theme.KickPlayer" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/kick_green</item>
        <item name="android:statusBarColor">@color/black_bg</item>
    </style>

    <style name="Theme.KickPlayer.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <color name="kick_green">#53fc18</color>
    <color name="black_bg">#111111</color>
    <color name="white">#FFFFFF</color>
</resources>
